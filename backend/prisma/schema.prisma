generator client {
  provider = "prisma-client-js"
  output = "../src/generated/client"
}

datasource db {
  provider = "postgresql"
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model profiles {
  id             String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  full_name      String? @db.VarChar
  notion_user_id String? @db.VarChar
  avatar_url     String?
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model project {
  id              String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title           String            @db.VarChar
  notion_db_id    String            @unique @db.VarChar
  description     String?
  created_at      DateTime?         @default(now()) @db.Timestamp(6)
  updated_at      DateTime?         @db.Timestamp(6)
  task            task[]
  workflow_status workflow_status[]
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model sync_log {
  id            BigInt   @id @default(autoincrement())
  task_id       String   @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  direction     String?  @db.VarChar
  sync_status   String?  @default("PENDING") @db.VarChar
  error_message String?
  retry_count   Int?     @default(0) @db.SmallInt
  synced_at     DateTime @db.Timestamptz(6)
  task          task     @relation(fields: [task_id], references: [id], onDelete: Cascade)
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model task {
  id              String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  project_id      String?          @db.Uuid
  status_id       String?          @db.Uuid
  notion_page_id  String?          @unique @db.VarChar
  title           String           @db.VarChar
  deleted_at      DateTime?        @db.Timestamp(6)
  content         String?
  start_date      DateTime?        @db.Timestamp(6)
  end_date        DateTime?        @db.Timestamp(6)
  priority        String?          @db.VarChar
  assignees       Json?
  tags            String?
  raw_notion_data Json?
  created_at      DateTime?        @default(now()) @db.Timestamp(6)
  updated_at      DateTime?        @default(now()) @db.Timestamp(6)
  sync_log        sync_log[]
  project         project?         @relation(fields: [project_id], references: [id], onDelete: Cascade)
  workflow_status workflow_status? @relation(fields: [status_id], references: [id], onDelete: Cascade)
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model workflow_status {
  id               String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  project_id       String  @db.Uuid
  name             String  @db.VarChar
  sort_ordr        Int?    @default(0) @db.SmallInt
  notion_option_id String? @db.VarChar
  task             task[]
  project          project @relation(fields: [project_id], references: [id], onDelete: Cascade)
}
